---
import Layout from '../layouts/Layout.astro';
import "../styles/global.css";
---

<Layout>
  <!-- Sección Hero con efecto más metálico y dinámico -->
  <section class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 text-white py-24 relative overflow-hidden">
    <!-- Efecto de brillo sutil en el fondo -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.03),transparent_40%)]"></div>
    
    <div class="container mx-auto px-4 text-center relative z-10">
      <!-- Logo SVG con tamaño reducido - reducido espacio inferior de mb-10 a mb-4 -->
      <div class="flex items-center justify-center mb-4">
        <svg width="100" height="100" viewBox="0 0 140 140" class="filter drop-shadow(0 0 8px rgba(255,215,0,0.3))">
          <!-- Efecto de brillo detrás del logo -->
          <defs>
            <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
              <feComposite in="SourceGraphic" in2="coloredBlur" operator="over"/>
            </filter>
          </defs>
          
          <!-- Nodo central con efecto dorado más brillante -->
          <circle cx="70" cy="70" r="30" fill="url(#enhanced-gold-gradient)" filter="url(#glow)" />
          
          <!-- Food trucks (puntos) con brillo -->
          <circle cx="25" cy="30" r="8" fill="url(#enhanced-gold-gradient)" filter="url(#glow)" />
          <circle cx="115" cy="30" r="8" fill="url(#enhanced-gold-gradient)" filter="url(#glow)" />
          <circle cx="25" cy="110" r="8" fill="url(#enhanced-gold-gradient)" filter="url(#glow)" />
          <circle cx="115" cy="110" r="8" fill="url(#enhanced-gold-gradient)" filter="url(#glow)" />
          
          <!-- Líneas conectoras que parecen brillar -->
          <path d="M25,30 L70,70 L115,30 M25,110 L70,70 L115,110" 
                stroke="url(#enhanced-gold-gradient)" stroke-width="4" filter="url(#glow)" fill="none" stroke-linecap="round" />
          
          <!-- Definición de gradientes mejorados -->
          <defs>
            <!-- Gradiente dorado más vibrante -->
            <radialGradient id="enhanced-gold-gradient" cx="50%" cy="50%" r="75%" fx="50%" fy="40%">
              <stop offset="0%" stop-color="#fff6bd" /> <!-- Dorado muy claro casi blanco -->
              <stop offset="30%" stop-color="#f5d485" /> <!-- Dorado claro -->
              <stop offset="60%" stop-color="#daa520" /> <!-- Dorado medio -->
              <stop offset="100%" stop-color="#b8860b" /> <!-- Dorado oscuro -->
            </radialGradient>
          </defs>
        </svg>
        
        <!-- Texto BINDU al lado del logo -->
        <h1 class="text-6xl font-bold ml-4 text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-300">BINDU</h1>
      </div>
      
      <!-- Línea amarilla alargada - reducido margen inferior de mb-10 a mb-8 -->
      <div class="h-1 w-64 bg-gradient-to-r from-yellow-300 via-yellow-500 to-yellow-300 mx-auto mb-8 rounded-full shadow-lg"></div>
      
      <p class="text-2xl mb-8 text-transparent bg-clip-text bg-gradient-to-r from-gray-100 to-white font-semibold">Un pago único para toda tu experiencia en food trucks</p>
      <p class="text-xl mb-10 max-w-3xl mx-auto text-gray-300">Sistema de Pago Agrupado de Pedidos (PAP) que revoluciona la experiencia de consumo en parques de food trucks en República Dominicana</p>
      <button class="bg-gradient-to-r from-yellow-500 to-amber-500 text-gray-900 font-bold py-4 px-12 rounded-md text-lg hover:from-yellow-400 hover:to-amber-400 transition duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
        Conoce más
      </button>
    </div>
  </section>

  <!-- Sección Problema/Solución -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center">
        <div class="md:w-1/2 mb-10 md:mb-0">
          <h2 class="text-3xl font-bold mb-8 text-gray-900">El problema actual</h2>
          <ul class="space-y-5 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="text-red-600 mr-3 text-xl">✖</span>
              Múltiples pagos en diferentes food trucks
            </li>
            <li class="flex items-start">
              <span class="text-red-600 mr-3 text-xl">✖</span>
              Largas filas y tiempo perdido en cada transacción
            </li>
            <li class="flex items-start">
              <span class="text-red-600 mr-3 text-xl">✖</span>
              Experiencia fragmentada y complicada
            </li>
            <li class="flex items-start">
              <span class="text-red-600 mr-3 text-xl">✖</span>
              Dificultad para manejar efectivo y tarjetas en múltiples lugares
            </li>
          </ul>
        </div>
        <div class="md:w-1/2 md:pl-16">
          <h2 class="text-3xl font-bold mb-8 text-gray-900">La solución Bindu</h2>
          <ul class="space-y-5 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">✓</span>
              Un solo pago para todo lo consumido
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">✓</span>
              Sistema de token único que acumula todos tus pedidos
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">✓</span>
              Flexibilidad de pago: tarjeta o efectivo
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">✓</span>
              Distribución automática de ingresos a los food trucks
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Cómo funciona - con círculos en gris cromado -->
  <section class="py-20 bg-gray-100">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-4xl font-bold mb-16 text-gray-900">¿Cómo funciona?</h2>
      <div class="flex flex-col md:flex-row justify-between items-center space-y-10 md:space-y-0 md:space-x-8">
        <div class="bg-white rounded-lg shadow-xl p-10 flex flex-col items-center max-w-xs mx-auto md:mx-0 transform hover:translate-y-[-5px] hover:shadow-2xl transition duration-300">
          <div class="bg-gradient-to-br from-gray-600 via-gray-500 to-gray-600 text-yellow-300 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mb-6 border border-gray-400 shadow-inner relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-t from-transparent via-gray-100/10 to-transparent opacity-50"></div>
            <span class="relative z-10">1</span>
          </div>
          <h3 class="text-xl font-bold mb-4 text-gray-900">Recibe tu token</h3>
          <p class="text-gray-700">Al llegar al parque, recibe un sencillo token numérico único</p>
        </div>
        <div class="bg-white rounded-lg shadow-xl p-10 flex flex-col items-center max-w-xs mx-auto md:mx-0">
          <div class="bg-gradient-to-br from-gray-700 via-gray-500 to-gray-600 text-yellow-400 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mb-6 border border-gray-400 shadow-inner">2</div>
          <h3 class="text-xl font-bold mb-4 text-gray-900">Disfruta sin preocupaciones</h3>
          <p class="text-gray-700">Cada food truck registra tus consumos con tu token</p>
        </div>
        <div class="bg-white rounded-lg shadow-xl p-10 flex flex-col items-center max-w-xs mx-auto md:mx-0">
          <div class="bg-gradient-to-br from-gray-700 via-gray-500 to-gray-600 text-yellow-400 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mb-6 border border-gray-400 shadow-inner">3</div>
          <h3 class="text-xl font-bold mb-4 text-gray-900">Un solo pago al final</h3>
          <p class="text-gray-700">Paga una única vez con tarjeta o efectivo el total de tu consumo</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold mb-16 text-center text-gray-900">Beneficios del sistema PAP</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="border border-gray-200 rounded-lg p-10 hover:shadow-xl transition duration-300">
          <h3 class="text-2xl font-bold mb-6 text-gray-800">Para los clientes</h3>
          <ul class="space-y-4">
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">•</span>
              <span class="text-gray-700 text-lg">Sin necesidad de descargar aplicaciones</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">•</span>
              <span class="text-gray-700 text-lg">Experiencia de pago sin fricciones</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">•</span>
              <span class="text-gray-700 text-lg">Reducción de tiempo en filas</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">•</span>
              <span class="text-gray-700 text-lg">Flexibilidad para pagar con tarjeta o efectivo</span>
            </li>
          </ul>
        </div>
        <div class="border border-gray-200 rounded-lg p-10 hover:shadow-xl transition duration-300">
          <h3 class="text-2xl font-bold mb-6 text-gray-800">Para los food trucks</h3>
          <ul class="space-y-4">
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">•</span>
              <span class="text-gray-700 text-lg">Distribución automática de ingresos</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">•</span>
              <span class="text-gray-700 text-lg">Mayor enfoque en atención al cliente</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">•</span>
              <span class="text-gray-700 text-lg">Reducción de errores en manejo de efectivo</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-3 text-xl">•</span>
              <span class="text-gray-700 text-lg">Reportes detallados de ventas e ingresos</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ - Preguntas Frecuentes -->
  <section class="py-20 bg-gray-100">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold mb-16 text-center text-gray-900">Preguntas Frecuentes</h2>
      
      <div class="max-w-3xl mx-auto space-y-6">
        <!-- Pregunta 1 -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <button class="faq-button w-full px-8 py-6 text-left text-lg font-bold flex justify-between items-center text-gray-900">
            ¿Qué es un token Bindu y cómo funciona?
            <svg class="w-6 h-6 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="faq-answer px-8 py-6 border-t border-gray-200 hidden">
            <p class="text-gray-700">Un token Bindu es un identificador único (generalmente un código numérico) que recibes al llegar al parque de food trucks. Este token registra todos tus consumos en los diferentes establecimientos, permitiéndote pagar una sola vez al final de tu experiencia. No requiere tecnología especial, es simplemente una tarjeta o ficha con tu código personal.</p>
          </div>
        </div>
        
        <!-- Pregunta 2 -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <button class="faq-button w-full px-8 py-6 text-left text-lg font-bold flex justify-between items-center text-gray-900">
            ¿Necesito una app para pagar?
            <svg class="w-6 h-6 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="faq-answer px-8 py-6 border-t border-gray-200 hidden">
            <p class="text-gray-700">No, una de las grandes ventajas de Bindu es que no necesitas descargar ninguna aplicación. El sistema está diseñado para eliminar fricciones en la experiencia del cliente. Simplemente usas tu token físico y pagas una sola vez, con tarjeta o efectivo, cuando termines de consumir.</p>
          </div>
        </div>
        
        <!-- Pregunta 3 -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <button class="faq-button w-full px-8 py-6 text-left text-lg font-bold flex justify-between items-center text-gray-900">
            ¿Qué métodos de pago acepta Bindu?
            <svg class="w-6 h-6 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="faq-answer px-8 py-6 border-t border-gray-200 hidden">
            <p class="text-gray-700">Bindu acepta todos los métodos de pago disponibles en los puntos de venta (POS) del parque de food trucks. Puedes pagar con cualquier tarjeta de débito o crédito (Visa, Mastercard, etc.) o con efectivo. La flexibilidad es una de nuestras prioridades para asegurar que todos los clientes puedan disfrutar de la experiencia Bindu.</p>
          </div>
        </div>
        
        <!-- Pregunta 4 -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <button class="faq-button w-full px-8 py-6 text-left text-lg font-bold flex justify-between items-center text-gray-900">
            ¿Cómo se distribuyen los pagos entre los food trucks?
            <svg class="w-6 h-6 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="faq-answer px-8 py-6 border-t border-gray-200 hidden">
            <p class="text-gray-700">El sistema PAP de Bindu registra automáticamente qué porción del pago corresponde a cada food truck basado en los pedidos realizados. Cuando pagas el total, el sistema distribuye electrónicamente los fondos a las cuentas bancarias de cada negocio, garantizando que cada uno reciba exactamente lo que le corresponde. Si pagas en efectivo, el sistema ajusta las transferencias considerando quién recibió el efectivo físico.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA con efecto cromado plateado -->
  <!-- CTA con efecto cromado -->
  <section class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 text-white py-20 shadow-lg">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-8">¿Listo para revolucionar la experiencia de pago en food trucks?</h2>
      <p class="text-xl mb-12 max-w-3xl mx-auto text-gray-300">Únete a la revolución de pagos centralizados con Bindu y el sistema PAP</p>
      <div class="flex flex-col sm:flex-row justify-center space-y-4 sm:space-y-0 sm:space-x-6">
        <button id="contactButton" class="bg-gradient-to-r from-yellow-600 to-yellow-500 text-gray-900 font-bold py-3 px-10 rounded-md text-lg hover:from-yellow-500 hover:to-yellow-400 transition duration-300">
          Contactar
        </button>
      </div>
    </div>
  </section>

  <!-- Footer - Actualizar con el nuevo logo mini -->
  <footer class="bg-gradient-to-b from-gray-800 to-gray-900 text-white py-12 relative overflow-hidden">
    <!-- Efecto de brillo sutil en el fondo -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(255,215,0,0.03),transparent_70%)]"></div>
    
    <div class="container mx-auto px-4 relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- Logo y descripción -->
        <div>
          <div class="flex items-center mb-4">
            <!-- Versión mini del nuevo logo con más brillo -->
            <svg width="30" height="30" viewBox="0 0 100 100" class="mr-3 filter drop-shadow(0 0 3px rgba(255,215,0,0.5))">
              <!-- Círculo central con gradiente dorado elegante -->
              <circle cx="50" cy="50" r="20" fill="url(#mini-enhanced-gold-gradient)" />
              
              <!-- Food trucks (puntos) alrededor -->
              <circle cx="20" cy="20" r="5" fill="url(#mini-enhanced-gold-gradient)" />
              <circle cx="80" cy="20" r="5" fill="url(#mini-enhanced-gold-gradient)" />
              <circle cx="20" cy="80" r="5" fill="url(#mini-enhanced-gold-gradient)" />
              <circle cx="80" cy="80" r="5" fill="url(#mini-enhanced-gold-gradient)" />
              
              <!-- Líneas conectoras más brillantes -->
              <path d="M20,20 L50,50 L80,20 M20,80 L50,50 L80,80" 
                    stroke="url(#mini-enhanced-gold-gradient)" stroke-width="2.5" fill="none" stroke-linecap="round" />
              
              <!-- Gradiente dorado mejorado para versión mini -->
              <defs>
                <radialGradient id="mini-enhanced-gold-gradient" cx="50%" cy="50%" r="75%" fx="50%" fy="40%">
                  <stop offset="0%" stop-color="#fff6bd" />
                  <stop offset="30%" stop-color="#f5d485" />
                  <stop offset="60%" stop-color="#daa520" />
                  <stop offset="100%" stop-color="#b8860b" />
                </radialGradient>
              </defs>
            </svg>
            <span class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-300">BINDU</span>
          </div>
          <p class="text-gray-400 mb-6">Sistema de Pago Agrupado de Pedidos (PAP) que revoluciona la experiencia en parques de food trucks.</p>
          
          <!-- Información de contacto con íconos más vibrantes -->
          <div class="space-y-2">
            <p class="flex items-center">
              <svg class="w-5 h-5 mr-3 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              <span>info@bindu.do</span>
            </p>
            <p class="flex items-center">
              <svg class="w-5 h-5 mr-3 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              <span>+1 809-555-0123</span>
            </p>
          </div>
        </div>
        
        <!-- Enlaces rápidos -->
        <div>
          <h3 class="text-xl font-bold mb-6 text-yellow-400">Enlaces rápidos</h3>
          <ul class="space-y-3">
            <li><a href="#" class="text-gray-400 hover:text-white transition duration-300">Inicio</a></li>
            <li><a href="#" class="text-gray-400 hover:text-white transition duration-300">Cómo funciona</a></li>
            <li><a href="#" class="text-gray-400 hover:text-white transition duration-300">Beneficios</a></li>
            <li><a href="#" class="text-gray-400 hover:text-white transition duration-300">Política de privacidad</a></li>
            <li><a href="#" class="text-gray-400 hover:text-white transition duration-300">Términos y condiciones</a></li>
          </ul>
        </div>
        
        <!-- Redes sociales -->
        <div>
          <h3 class="text-xl font-bold mb-6 text-yellow-400">Síguenos</h3>
          <div class="flex space-x-4">
            <a href="#" class="bg-gray-700 hover:bg-yellow-400 hover:text-black transition duration-300 w-10 h-10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.77 7.46H14.5v-1.9c0-.9.6-1.1 1-1.1h3V.5h-4.33C10.24.5 9.5 3.44 9.5 5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4z"/>              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </footer>

  <!-- Modal de Contacto - Cabecera con efecto cromado -->
  <div id="contactModal" class="fixed inset-0 bg-black/50 bg-opacity-75 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-lg max-w-md w-full mx-4 overflow-hidden">
      <div class="bg-gradient-to-r from-gray-800 via-gray-700 to-gray-800 px-6 py-4 flex justify-between items-center">
        <h3 class="text-xl font-bold text-white">Contáctanos</h3>
        <button id="closeModal" class="text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <div class="p-6">
        <form id="contactForm" class="space-y-4">
          <div>
            <label for="name" class="block text-gray-700 font-medium mb-1">Nombre</label>
            <input type="text" id="name" name="nombre" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400" placeholder="Tu nombre">
          </div>
          <div>
            <label for="email" class="block text-gray-700 font-medium mb-1">Correo electrónico</label>
            <input type="email" id="email" name="email" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400" placeholder="tucorreo@ejemplo.com">
          </div>
          <div>
            <label for="phone" class="block text-gray-700 font-medium mb-1">Teléfono</label>
            <input type="tel" id="phone" name="telefono" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400" placeholder="(809) 555-0123">
          </div>
          <div>
            <label for="message" class="block text-gray-700 font-medium mb-1">Mensaje</label>
            <textarea id="message" name="mensaje" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-yellow-400" placeholder="¿En qué podemos ayudarte?"></textarea>
          </div>
          <button type="submit" class="w-full bg-yellow-400 text-black font-bold py-3 rounded-md hover:bg-yellow-300 transition duration-300">
            Enviar mensaje
          </button>
          <div id="formStatus" class="hidden"></div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<!-- Corrección: Scripts cliente para Astro -->
<script>
  // Funcionalidad para las FAQ (acordeón)
  document.addEventListener('DOMContentLoaded', () => {
    const faqButtons = document.querySelectorAll('.faq-button');
    
    faqButtons.forEach(button => {
      button.addEventListener('click', () => {
        const answer = button.nextElementSibling;
        const icon = button.querySelector('svg');
        
        // Alternar visibilidad de la respuesta
        if (answer) {
          answer.classList.toggle('hidden');
        }
        
        // Rotar icono cuando está abierto
        if (icon) {
          if (answer && answer.classList.contains('hidden')) {
            icon.classList.remove('rotate-180');
          } else {
            icon.classList.add('rotate-180');
          }
        }
      });
    });
    
    // Funcionalidad para el modal de contacto
    const contactButton = document.getElementById('contactButton');
    const contactModal = document.getElementById('contactModal');
    const closeModal = document.getElementById('closeModal');
    
    if (contactButton && contactModal && closeModal) {
      // Abrir modal
      contactButton.addEventListener('click', () => {
        contactModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Evitar scroll
      });
      
      // Cerrar modal con botón X
      closeModal.addEventListener('click', () => {
        contactModal.classList.add('hidden');
        document.body.style.overflow = 'auto'; // Restaurar scroll
      });
      
      // Cerrar modal al hacer clic fuera
      contactModal.addEventListener('click', (e) => {
        if (e.target === contactModal) {
          contactModal.classList.add('hidden');
          document.body.style.overflow = 'auto';
        }
      });
    }
  });

  // Funcionalidad para el formulario de contacto
  document.addEventListener('DOMContentLoaded', () => {
    const contactForm: any = document.getElementById('contactForm');
    const formStatus: any = document.getElementById('formStatus');
    
    if (contactForm) {
      contactForm.addEventListener('submit', async (e: any) => {
        e.preventDefault();
        if (!formStatus) return;
        // Mostrar estado de carga
        formStatus.textContent = "Enviando mensaje...";
        formStatus.className = "mt-4 py-2 px-4 bg-blue-100 text-blue-800 rounded";
        formStatus.classList.remove('hidden');
        
        // Recoger datos del formulario
        const formData = {
          nombre: contactForm.nombre.value,
          email: contactForm.email.value,
          telefono: contactForm.telefono.value,
          mensaje: contactForm.mensaje.value
        };
        
        // try {
          // Enviar datos al endpoint
          const response = await fetch('/api/enviarCorreo', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
          });
          
          const result = await response.json();

		  console.log(result);
          
          if (result.success) {
            // Mensaje enviado con éxito
            formStatus.textContent = "¡Mensaje enviado con éxito! Nos pondremos en contacto contigo pronto.";
            formStatus.className = "mt-4 py-2 px-4 bg-green-100 text-green-800 rounded";
            
            // Limpiar formulario
            contactForm.reset();
          } else {
            // Error al enviar
            formStatus.textContent = "Hubo un problema al enviar el mensaje. Por favor, intenta de nuevo.";
            formStatus.className = "mt-4 py-2 px-4 bg-red-100 text-red-800 rounded";
          }
        // } catch (error) {
        //   console.error('Error:', error);
        //   formStatus.textContent = "Error al conectar con el servidor. Por favor, intenta más tarde.";
        //   formStatus.className = "mt-4 py-2 px-4 bg-red-100 text-red-800 rounded";
        // }
      });
    }
  });
</script>
