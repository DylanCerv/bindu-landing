{
    "version": 2,
    "builds": [
      {
        "src": "package.json",
        "use": "@vercel/static-build",
        "config": {
          "zeroConfig": true
        }
      }
    ],
    "functions": {
      "api/*.js": {
        "runtime": "nodejs20.x"
      },
      "api/*.ts": {
        "runtime": "nodejs20.x"
      },
      "_render": {
        "runtime": "nodejs20.x"
      }
    }
  }